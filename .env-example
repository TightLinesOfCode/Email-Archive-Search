# -----------------------------------------------------------------------------
# Archive Directory
#
# EXTERNAL (this machine) → INTERNAL (inside Docker container)
#   LOCAL_MACHINE_ARCHIVE_DIR           → /pop-email-archive  (fixed — do not change)
#
# Only LOCAL_MACHINE_ARCHIVE_DIR should be changed. The internal path /pop-email-archive
# is hard-coded into the container and must stay as-is.
#
# LOCAL_MACHINE_ARCHIVE_DIR can be a path relative to the repo root or an absolute path:
#   ./pop-email-archive        ← default, a folder inside this repo
#   /Volumes/MyDrive/Email     ← absolute path, e.g. external drive
#   /mnt/nas/email             ← absolute path, e.g. NAS mount
# -----------------------------------------------------------------------------
LOCAL_MACHINE_ARCHIVE_DIR=./pop-email-archive

# Port the web UI is served on (host and container).
PORT=5000

# Gmail POP3 (incoming)
POP_HOST=pop.gmail.com
POP_PORT=995
POP_USE_SSL=true

# -----------------------------------------------------------------------------
# Fetch Date Range (optional)
#
# Limit which emails are downloaded based on the date they were sent.
# Format: YYYY-MM-DD   Example: 2024-01-01
# Leave blank to apply no limit on that end of the range.
#
#   FETCH_DATE_FROM   — only download emails sent on or after this date
#   FETCH_DATE_TO     — only download emails sent on or before this date
#
# Examples:
#   FETCH_DATE_FROM=2024-01-01   FETCH_DATE_TO=2024-12-31  → full year 2024
#   FETCH_DATE_FROM=2024-06-01   FETCH_DATE_TO=            → everything from June 2024 onwards
#   FETCH_DATE_FROM=             FETCH_DATE_TO=2023-12-31  → everything up to end of 2023
# -----------------------------------------------------------------------------
FETCH_DATE_FROM=
FETCH_DATE_TO=

# -----------------------------------------------------------------------------
# Fetch Limit
#
# Maximum number of emails to download in a single run.
# Set to ALL to download every available message (default behaviour).
# Set to a number (e.g. 10) to cap the run — useful for testing.
#
#   FETCH_LIMIT=ALL   — no limit, download everything
#   FETCH_LIMIT=10    — download at most 10 new emails per run
# -----------------------------------------------------------------------------
FETCH_LIMIT=10

# -----------------------------------------------------------------------------
# Read-Only Mode
#
# When READ_ONLY=true, emails are fetched and archived locally but nothing is
# ever deleted from the POP server — regardless of POP_LEAVE_ON_SERVER or
# POP_LEAVE_DAYS. Use this to safely test or do an initial archive run without
# any risk of removing mail from Gmail.
# -----------------------------------------------------------------------------
READ_ONLY=true

# Retention: keep messages on the server for this many days after first archive.
# Set POP_LEAVE_ON_SERVER=false to delete immediately after fetching.
# Set POP_LEAVE_DAYS=0 with POP_LEAVE_ON_SERVER=true to keep forever.
POP_LEAVE_ON_SERVER=true
POP_LEAVE_DAYS=365

# Gmail SMTP (outgoing — needed if sending/forwarding)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true

# Gmail account credentials
# Use an App Password, not your normal Gmail password.
# Generate one at: https://myaccount.google.com/apppasswords
EMAIL_ADDRESS=
EMAIL_PASSWORD=
