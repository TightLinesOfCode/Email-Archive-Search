# =============================================================================
# Email Account Credentials
# Use an App Password, not your normal Gmail password.
# Generate one at: https://myaccount.google.com/apppasswords
# =============================================================================
EMAIL_ADDRESS=
EMAIL_PASSWORD=

# =============================================================================
# Mail Protocol
#
#   IMAP  — downloads all folders (Inbox, Sent, Spam, custom labels, etc.)
#            Recommended for a complete archive.
#   POP3  — downloads Inbox only (simpler, but no folder support)
# =============================================================================
MAIL_PROTOCOL=IMAP

# =============================================================================
# IMAP Settings  (used when MAIL_PROTOCOL=IMAP)
# =============================================================================
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USE_SSL=true

# =============================================================================
# POP3 Settings  (used when MAIL_PROTOCOL=POP3)
# =============================================================================
POP_HOST=pop.gmail.com
POP_PORT=995
POP_USE_SSL=true

# -----------------------------------------------------------------------------
# Server Retention  (POP3 only)
#
# Controls whether messages are removed from the mail server after archiving.
#   LEAVE_ON_SERVER=true   — keep messages on the server
#   LEAVE_ON_SERVER=false  — delete from server immediately after archiving
#
#   LEAVE_DAYS=365  — delete from server once archived copy is this many days old
#   LEAVE_DAYS=0    — keep on server forever (only applies if LEAVE_ON_SERVER=true)
# -----------------------------------------------------------------------------
LEAVE_ON_SERVER=false
LEAVE_DAYS=3

# =============================================================================
# SMTP Settings  (outgoing — needed if sending/forwarding)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true

# =============================================================================
# Fetch Behavior  (applies to both IMAP and POP3)
# =============================================================================

# Limit downloads to a date range. Format: YYYY-MM-DD. Leave blank for no limit.
#   FETCH_DATE_FROM   — only download emails sent on or after this date
#   FETCH_DATE_TO     — only download emails sent on or before this date
FETCH_DATE_FROM=
FETCH_DATE_TO=

# Maximum emails to download per run. Use ALL for no limit.
FETCH_LIMIT=ALL

# When true, emails are archived locally but the server is never modified.
# Overrides LEAVE_ON_SERVER. Recommended for initial runs and testing.
READ_ONLY=false

# =============================================================================
# Infrastructure
# =============================================================================

# Port the web UI is served on.
PORT=12987

# -----------------------------------------------------------------------------
# Archive Directory
#
# EXTERNAL (this machine) → INTERNAL (inside Docker container)
#   LOCAL_MACHINE_ARCHIVE_DIR  →  /pop-email-archive  (fixed — do not change)
#
# Only LOCAL_MACHINE_ARCHIVE_DIR should be changed. Examples:
#   ./pop-email-archive        ← default, a folder inside this repo
#   /Volumes/MyDrive/Email     ← absolute path, e.g. external drive
#   /mnt/nas/email             ← absolute path, e.g. NAS mount
# -----------------------------------------------------------------------------
LOCAL_MACHINE_ARCHIVE_DIR=./pop-email-archive
